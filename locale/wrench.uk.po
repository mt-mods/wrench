msgid "Wrench"
msgstr "Монтажний ключ"

msgid ""
"Adds a wrench to pick up nodes with inventories, such as chests, and transport"
" them to another location."
msgstr ""
"Додає монтажний ключ для підняття блоків з інвентарем, як-от скриньок, та пере"
"несення їх до іншого місця."

msgid "Not enough room in inventory to pickup node."
msgstr "Не вистачає місця у інвентарі, щоб узяти блок."

msgid "Cannot pickup node containing @1."
msgstr "Неможливо узяти блок, що містить @1."

msgid "Cannot pickup node. Owned by @1."
msgstr "Неможливо узяти блок. Його власником є @1."

msgid "Cannot pickup node. Nesting inventories is not allowed."
msgstr "Неможливо узяти блок. Вкладені інвентарі не дозволені."

msgid "Cannot pickup node. Node contains too much metadata."
msgstr "Неможливо узяти блок, оскільки він містить забагато метаданих."

msgid "Cannot pickup node. Node is missing inventory."
msgstr "Неможливо взяти блок, оскільки у нього немає інвентаря."

msgid "Cannot pickup node. Node contains unknown metadata."
msgstr "Неможливо взяти блок, оскільки він містить невідомі метадані."

msgid "@1 with items"
msgstr "@1 з предметами"

msgid "@1 with text \"@2\""
msgstr "@1 з текстом «@2»"

msgid "@1 with channel \"@2\""
msgstr "@1 з каналом «@2»"

msgid "@1 with configuration"
msgstr "@1 з конфігурацією"

msgid "@1 with armor"
msgstr "@1 з бронею"

msgid "@1 with code"
msgstr "@1 з кодом"

msgid "@1 with game \"@2\" vs. \"@3\""
msgstr "@1 з грою «@2» проти «@3»"

msgid "@1 with item \"@2\""
msgstr "@1 з предметом «@2»"

msgid "@1 (light level @2) with channel \"@3\""
msgstr "@1 (рівень освітлення @2) з каналом «@3»"
