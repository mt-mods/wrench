msgid "Wrench"
msgstr "Kunci Pas"

msgid "Not enough room in inventory to pickup node."
msgstr "Tidak cukup ruang dalam inventaris untuk mengambil nodus."

msgid "Cannot pickup node containing @1."
msgstr "Tidak dapat mengambil nodus yang berisi @1."

msgid "Cannot pickup node. Owned by @1."
msgstr "Tidak dapat mengambil nodus. Dimiliki oleh @1."

msgid "Cannot pickup node. Nesting inventories is not allowed."
msgstr "Tidak dapat mengambil nodus. Inventaris bersusun tidak dibolehkan."

msgid "Cannot pickup node. Node contains too much metadata."
msgstr "Tidak dapat mengambil nodus. Nodus berisi terlalu banyak metadata."

msgid "Cannot pickup node. Node is missing inventory."
msgstr "Tidak dapat mengambil nodus. Nodus kehilangan inventaris."

msgid "Cannot pickup node. Node contains unknown metadata."
msgstr "Tidak dapat mengambil nodus. Nodus mengandung metadata yang tidak diketahui."

